<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ===== Generic CCID smart-card readers (USB class 0x0B = 11) =====
         Matches any spec-compliant vendor. Many readers declare class 11 at the
         INTERFACE level (device descriptor class 0); the attach matcher checks
         interfaces too, so both layouts are caught. -->
    <usb-device class="11" subclass="0" protocol="0" />
    <usb-device class="11" subclass="0" protocol="1" />
    <usb-device class="11" subclass="0" protocol="2" />

    <!-- ===== Common USB-Serial bridge chipsets (vendor-specific class, VID/PID only) ===== -->
    <!-- WCH CH340 / CH341 -->
    <usb-device vendor-id="6790" product-id="29987" />   <!-- 0x1A86 / 0x7523 -->
    <usb-device vendor-id="6790" product-id="21795" />   <!-- 0x1A86 / 0x5523 -->
    <!-- Silicon Labs CP210x -->
    <usb-device vendor-id="4292" product-id="60000" />   <!-- 0x10C4 / 0xEA60 -->
    <usb-device vendor-id="4292" product-id="60016" />   <!-- 0x10C4 / 0xEA70 -->
    <!-- FTDI FT232 / FT2232 / FT4232 / FT232H / FT230X -->
    <usb-device vendor-id="1027" product-id="24577" />   <!-- 0x0403 / 0x6001 -->
    <usb-device vendor-id="1027" product-id="24592" />   <!-- 0x0403 / 0x6010 -->
    <usb-device vendor-id="1027" product-id="24593" />   <!-- 0x0403 / 0x6011 -->
    <usb-device vendor-id="1027" product-id="24596" />   <!-- 0x0403 / 0x6014 -->
    <usb-device vendor-id="1027" product-id="24597" />   <!-- 0x0403 / 0x6015 -->
    <!-- Prolific PL2303 -->
    <usb-device vendor-id="1659" product-id="8963" />    <!-- 0x067B / 0x2303 -->
    <!-- CDC-ACM class devices (modern serial readers enumerating as class 2) -->
    <usb-device class="2" subclass="2" protocol="1" />

    <!-- ===== Brand A (existing SDK) =====
         TODO(BrandA): insert exact VID/PID from the Brand A datasheet:
    <usb-device vendor-id="XXXX" product-id="YYYY" /> -->
</resources>
